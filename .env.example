# Required — IMAP
IMAP_HOST=imap.example.com
IMAP_USER=user@example.com
IMAP_PASSWORD=

# Optional — IMAP (defaults shown)
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true

# Required — SMTP
SMTP_HOST=smtp.example.com
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Optional — SMTP (defaults shown)
SMTP_FROM_NAME="Your Name"
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_ALLOWED_FROM=user@example.com,vendas@example.com,suporte@example.com

# HTTP Authentication (optional — leave empty to disable)
MCP_AUTH_TOKEN=
